//// COMPUTE THE MINIMUM OF TWO VALUES
// Sys.min(x, y)
// Returns the smaller value.

function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_ARG0

    // argument 1 is smaller or equal
    push argument 1
    return

label MIN_ARG0
    push argument 0
    return



//// COMPUTE THE MAXIMUM OF TWO VALUES
// Sys.max(x, y)
// Returns the larger value.

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_ARG0

    // argument 1 is larger or equal
    push argument 1
    return

label MAX_ARG0
    push argument 0
    return



//// COMPUTE THE RANGE OF AN ARRAY
// Sys.range(baseAddress, n)
// Returns max(array) - min(array)
// If n <= 1, returns 0.

function Sys.range 2
    // local 0 = minimum
    // local 1 = maximum
    // temp 0 = index i
    // temp 1 = base address
    // temp 2 = number of elements n
    // temp 3 = current array value

    // If n < 2, range is 0
    push argument 1
    push constant 2
    lt
    if-goto RANGE_ZERO

    // temp 1 = base address
    push argument 0
    pop temp 1

    // temp 2 = n
    push argument 1
    pop temp 2

    // local 0 = array[0]
    push temp 1
    pop pointer 1
    push that 0
    pop local 0

    // local 1 = array[0]
    push local 0
    pop local 1

    // i = 1
    push constant 1
    pop temp 0

label RANGE_LOOP
    // while i < n
    push temp 0
    push temp 2
    lt
    if-goto RANGE_BODY

    goto RANGE_DONE

label RANGE_BODY
    // current = array[i]
    push temp 1
    push temp 0
    add
    pop pointer 1
    push that 0
    pop temp 3

    // minimum = Sys.min(minimum, current)
    push local 0
    push temp 3
    call Sys.min 2
    pop local 0

    // maximum = Sys.max(maximum, current)
    push local 1
    push temp 3
    call Sys.max 2
    pop local 1

    // i = i + 1
    push temp 0
    push constant 1
    add
    pop temp 0

    goto RANGE_LOOP

label RANGE_DONE
    // return maximum - minimum
    push local 1
    push local 0
    sub
    return

label RANGE_ZERO
    push constant 0
    return



// Testing entry point.
// Keep this part for the supplied Sys.tst script.

function Sys.init 0
    call Sys.range 2

label WHILE
    goto WHILE