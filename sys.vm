// ============================================================
// Sys.init — entry point. The autograder will normally replace
// this with its own test code; just here so the file has an
// entry point and parses correctly.
// ============================================================
function Sys.init 0
    call Sys.range 2
label END
    goto END

// ============================================================
// Sys.min — returns the smaller of argument 0 and argument 1
// ============================================================
function Sys.min 0
    push argument 0
    push argument 1
    lt                      // arg0 < arg1 ?
    if-goto A_SMALL
    push argument 1         // arg0 >= arg1, so min is arg1
    return
label A_SMALL
    push argument 0         // arg0 < arg1, so min is arg0
    return

// ============================================================
// Sys.max — returns the larger of argument 0 and argument 1
// ============================================================
function Sys.max 0
    push argument 0
    push argument 1
    gt                      // arg0 > arg1 ?
    if-goto A_BIG
    push argument 1         // arg0 <= arg1, so max is arg1
    return
label A_BIG
    push argument 0         // arg0 > arg1, so max is arg0
    return

// ============================================================
// Sys.range — returns max - min of an array
//   argument 0 : address of first element
//   argument 1 : n (number of elements)
//   returns 0 if n <= 1
// ============================================================
function Sys.range 4
    // local 0 = running min
    // local 1 = running max
    // local 2 = loop index i
    // local 3 = current array element

    // if n > 1 continue, otherwise return 0
    push argument 1
    push constant 1
    gt
    if-goto START
    push constant 0
    return

label START
    // min = arr[0]   (set THAT to arg0, read that 0)
    push argument 0
    pop pointer 1
    push that 0
    pop local 0

    // max = arr[0]
    push argument 0
    pop pointer 1
    push that 0
    pop local 1

    // i = 1
    push constant 1
    pop local 2

label LOOP
    // exit when i >= n  (i.e. when (i < n) is false)
    push local 2
    push argument 1
    lt
    not
    if-goto END

    // current = arr[i]  -> RAM[arg0 + i]
    push argument 0
    push local 2
    add
    pop pointer 1
    push that 0
    pop local 3

    // min = Sys.min(min, current)
    push local 0
    push local 3
    call Sys.min 2
    pop local 0

    // max = Sys.max(max, current)
    push local 1
    push local 3
    call Sys.max 2
    pop local 1

    // i++
    push local 2
    push constant 1
    add
    pop local 2

    goto LOOP

label END
    // return max - min
    push local 1
    push local 0
    sub
    return