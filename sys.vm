function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_FIRST
    push argument 1
    return
label MIN_FIRST
    push argument 0
    return


function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_FIRST
    push argument 1
    return
label MAX_FIRST
    push argument 0
    return


function Sys.range 2
    // If n <= 1, return 0
    push argument 1
    push constant 1
    gt
    not
    if-goto IS_ZERO

    // Initialize min (local 0) and max (local 1) to arr[0]
    push argument 0
    pop pointer 1
    push that 0
    pop local 0
    push argument 0
    pop pointer 1
    push that 0
    pop local 1

label LOOP
    // Decrement remaining count
    push argument 1
    push constant 1
    sub
    pop argument 1

    // If count reached 0, we're done
    push argument 1
    push constant 0
    eq
    if-goto DONE

    // Advance to next array element
    push argument 0
    push constant 1
    add
    pop argument 0

    // THAT = current address
    push argument 0
    pop pointer 1

    // min = Sys.min(min, *current)
    push local 0
    push that 0
    call Sys.min 2
    pop local 0

    // max = Sys.max(max, *current)
    push local 1
    push that 0
    call Sys.max 2
    pop local 1

    goto LOOP

label DONE
    // Push max, push min, compute difference
    push local 1
    push local 0
    sub
    return

label IS_ZERO
    push constant 0
    return


function Sys.init 0
    call Sys.range 2
label WHILE
    goto WHILE