//// Sys.min
//// Returns the smaller of the two arguments.

function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_RETURN_FIRST

    push argument 1
    return

label MIN_RETURN_FIRST
    push argument 0
    return



//// Sys.max
//// Returns the larger of the two arguments.

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_RETURN_FIRST

    push argument 1
    return

label MAX_RETURN_FIRST
    push argument 0
    return



//// Sys.range
//// argument 0 = base address of array
//// argument 1 = number of elements
//// returns maximum - minimum
//// if n <= 1, returns 0
////
//// local 0 = minimum
//// local 1 = maximum
//// local 2 = index
//// local 3 = current value

function Sys.range 4
    // if n <= 1, return 0
    push argument 1
    push constant 1
    gt
    if-goto RANGE_BEGIN

    push constant 0
    return

label RANGE_BEGIN
    // local 0 = array[0]
    push argument 0
    pop pointer 1
    push that 0
    pop local 0

    // local 1 = local 0
    push local 0
    pop local 1

    // index = 1
    push constant 1
    pop local 2

label RANGE_LOOP
    // continue while index < n
    push local 2
    push argument 1
    lt
    if-goto RANGE_CHECK_VALUE

    goto RANGE_FINISH

label RANGE_CHECK_VALUE
    // current value = array[index]
    push argument 0
    push local 2
    add
    pop pointer 1
    push that 0
    pop local 3

    // minimum = Sys.min(minimum, current value)
    push local 0
    push local 3
    call Sys.min 2
    pop local 0

    // maximum = Sys.max(maximum, current value)
    push local 1
    push local 3
    call Sys.max 2
    pop local 1

    // index++
    push local 2
    push constant 1
    add
    pop local 2

    goto RANGE_LOOP

label RANGE_FINISH
    // return maximum - minimum
    push local 1
    push local 0
    sub
    return



//// Entry point for the supplied test script.

function Sys.init 0
    call Sys.range 2

label END
    goto END