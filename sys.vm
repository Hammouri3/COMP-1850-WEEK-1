//// COMPUTE THE MINIMUM OF TWO VALUES

function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_FIRST

    push argument 1
    return

label MIN_FIRST
    push argument 0
    return



//// COMPUTE THE MAXIMUM OF TWO VALUES

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_FIRST

    push argument 1
    return

label MAX_FIRST
    push argument 0
    return



//// COMPUTE THE RANGE OF AN ARRAY
// argument 0 = array base address
// argument 1 = number of elements
// local 0 = current minimum
// local 1 = current maximum
// temp 0 = current address
// temp 1 = remaining elements
// temp 2 = current array value

function Sys.range 2
    // If n <= 1, return 0
    push argument 1
    push constant 1
    gt
    if-goto RANGE_START

    push constant 0
    return

label RANGE_START
    // temp 0 = base address
    push argument 0
    pop temp 0

    // min = array[0]
    push temp 0
    pop pointer 1
    push that 0
    pop local 0

    // max = array[0]
    push local 0
    pop local 1

    // current address = base + 1
    push temp 0
    push constant 1
    add
    pop temp 0

    // remaining = n - 1
    push argument 1
    push constant 1
    sub
    pop temp 1

label RANGE_LOOP
    // If remaining == 0, finish
    push temp 1
    push constant 0
    eq
    if-goto RANGE_DONE

    // current value = RAM[current address]
    push temp 0
    pop pointer 1
    push that 0
    pop temp 2

    // min = Sys.min(min, current)
    push local 0
    push temp 2
    call Sys.min 2
    pop local 0

    // max = Sys.max(max, current)
    push local 1
    push temp 2
    call Sys.max 2
    pop local 1

    // current address++
    push temp 0
    push constant 1
    add
    pop temp 0

    // remaining--
    push temp 1
    push constant 1
    sub
    pop temp 1

    goto RANGE_LOOP

label RANGE_DONE
    // return max - min
    push local 1
    push local 0
    sub
    return



//// ENTRY POINT
// Keep this exactly like the starter file.

function Sys.init 0
    call Sys.range 2

label WHILE
    goto WHILE