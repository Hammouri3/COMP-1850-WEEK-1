//// COMPUTE THE MINIMUM OF TWO VALUES
// Sys.min(x, y)
// Returns the smaller value.

function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_X

    push argument 1
    return

label MIN_X
    push argument 0
    return



//// COMPUTE THE MAXIMUM OF TWO VALUES
// Sys.max(x, y)
// Returns the larger value.

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_X

    push argument 1
    return

label MAX_X
    push argument 0
    return



//// COMPUTE THE RANGE OF AN ARRAY.
// Sys.range(baseAddress, numberOfElements)
// argument 0 = array base address
// argument 1 = number of elements
// Returns max - min
// If numberOfElements <= 1, returns 0.

function Sys.range 2
    // local 0 = min
    // local 1 = max
    // temp 0 = current address
    // temp 1 = remaining count
    // temp 2 = current value

    // if n <= 1, return 0
    push argument 1
    push constant 1
    gt
    if-goto RANGE_START

    push constant 0
    return

label RANGE_START
    // temp 0 = base address
    push argument 0
    pop temp 0

    // local 0 = array[0]
    push temp 0
    pop pointer 1
    push that 0
    pop local 0

    // local 1 = array[0]
    push local 0
    pop local 1

    // temp 0 = base address + 1
    push temp 0
    push constant 1
    add
    pop temp 0

    // temp 1 = n - 1
    push argument 1
    push constant 1
    sub
    pop temp 1

label RANGE_LOOP
    // if remaining count == 0, finish
    push temp 1
    push constant 0
    eq
    if-goto RANGE_DONE

    // temp 2 = RAM[current address]
    push temp 0
    pop pointer 1
    push that 0
    pop temp 2

    // local 0 = min(local 0, temp 2)
    push local 0
    push temp 2
    call Sys.min 2
    pop local 0

    // local 1 = max(local 1, temp 2)
    push local 1
    push temp 2
    call Sys.max 2
    pop local 1

    // current address++
    push temp 0
    push constant 1
    add
    pop temp 0

    // remaining count--
    push temp 1
    push constant 1
    sub
    pop temp 1

    goto RANGE_LOOP

label RANGE_DONE
    // return max - min
    push local 1
    push local 0
    sub
    return



// Do not change this part when submitting.

function Sys.init 0
    call Sys.range 2

label WHILE
    goto WHILE