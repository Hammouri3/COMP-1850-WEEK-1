//// COMPUTE THE MINIMUM OF TWO VALUES
// Sys.min(x, y)
// Returns the smaller of x and y.

function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_FIRST

    push argument 1
    return

label MIN_FIRST
    push argument 0
    return



//// COMPUTE THE MAXIMUM OF TWO VALUES
// Sys.max(x, y)
// Returns the larger of x and y.

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_FIRST

    push argument 1
    return

label MAX_FIRST
    push argument 0
    return



//// COMPUTE THE RANGE OF AN ARRAY
// Sys.range(base, n)
// argument 0 = address of first array element
// argument 1 = number of elements
// Returns max(array) - min(array)
// If n <= 1, returns 0.

function Sys.range 5
    // local 0 = minimum
    // local 1 = maximum
    // local 2 = index i
    // local 3 = base address
    // local 4 = current array value

    // If n < 2, return 0
    push argument 1
    push constant 2
    lt
    if-goto RANGE_ZERO

    // local 3 = base address
    push argument 0
    pop local 3

    // local 0 = array[0]
    push local 3
    pop pointer 1
    push that 0
    pop local 0

    // local 1 = array[0]
    push local 0
    pop local 1

    // local 2 = i = 1
    push constant 1
    pop local 2

label RANGE_LOOP
    // if i < n, continue
    push local 2
    push argument 1
    lt
    if-goto RANGE_BODY

    goto RANGE_DONE

label RANGE_BODY
    // current = array[i]
    push local 3
    push local 2
    add
    pop pointer 1
    push that 0
    pop local 4

    // minimum = Sys.min(minimum, current)
    push local 0
    push local 4
    call Sys.min 2
    pop local 0

    // maximum = Sys.max(maximum, current)
    push local 1
    push local 4
    call Sys.max 2
    pop local 1

    // i = i + 1
    push local 2
    push constant 1
    add
    pop local 2

    goto RANGE_LOOP

label RANGE_DONE
    // return maximum - minimum
    push local 1
    push local 0
    sub
    return

label RANGE_ZERO
    push constant 0
    return



// Keep this Sys.init section.

function Sys.init 0
    call Sys.range 2

label WHILE
    goto WHILE